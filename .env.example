# Google AI Studio API Key（必填）
GOOGLE_API_KEY=your-google-api-key

# Upstash Redis（必填，用于遥测统计）
UPSTASH_REDIS_REST_URL=https://your-redis.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-redis-token

# Dashboard 访问密码（可选，不设置则无需认证）
DASHBOARD_PASSWORD=your-dashboard-password

# CORS 允许的来源域名，逗号分隔（可选，不设置则允许所有）
CORS_ALLOWED_ORIGINS=https://your-frontend.com

# 错误告警 Webhook（可选）
# 钉钉机器人：https://oapi.dingtalk.com/robot/send?access_token=xxx
# Telegram Bot: https://api.telegram.org/bot<token>
ERROR_WEBHOOK_URL=
ERROR_WEBHOOK_TYPE=dingtalk  # dingtalk 或 telegram

# 告警静默时段（可选，默认启用）
# 北京时间 22:00-08:00 不发送 warning 级别告警（critical 始终发送）
QUIET_HOURS_ENABLED=true
QUIET_HOURS_START=22
QUIET_HOURS_END=8
